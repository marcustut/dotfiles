# secrets / machine-local
zuliprc

# fish: machine-generated universal vars
.config/fish/fish_variables

# fish: fisher-managed plugin files (reinstalled via `fisher update`)
.config/fish/functions/_*.fish
.config/fish/functions/fisher.fish
.config/fish/functions/fzf_configure_bindings.fish
.config/fish/functions/fish_greeting.fish
.config/fish/functions/fish_mode_prompt.fish
.config/fish/functions/fish_prompt.fish
.config/fish/functions/fish_title.fish
.config/fish/completions/fisher.fish
.config/fish/completions/fzf_configure_bindings.fish
.config/fish/conf.d/_pure_init.fish
.config/fish/conf.d/pure.fish
.config/fish/conf.d/fzf.fish
.config/fish/conf.d/done.fish

# fish: stale prompt backups
.config/fish/functions/*.pure-backup.fish

# claude code: track only core config, ignore state/secrets/local
.claude/*
!.claude/settings.json
!.claude/CLAUDE.md
!.claude/RTK.md
